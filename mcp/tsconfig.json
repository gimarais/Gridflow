{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "..",
    "declaration": true,
    "declarationMap": true,
    "baseUrl": "..",
    "types": ["node"],
    "paths": {
      "src/*": ["src/*"],
      "cli/*": ["cli/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
