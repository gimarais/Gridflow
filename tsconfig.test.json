{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "out",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": "."
  },
  "include": [
    "src/test/**/*.ts",
    "src/extension/**/*.ts",
    "src/shared/**/*.ts",
    "src/webview/store.ts",
    "src/webview/vscode.ts"
  ],
  "exclude": ["node_modules", "dist", "out", "out-webview"]
}
